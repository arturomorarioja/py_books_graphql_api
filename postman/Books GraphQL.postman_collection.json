				"body": {
					"mode": "graphql",
					"graphql": {
						"query": "mutation AddBook($title: String!, $author: String!) {\r\n  addBook(title: $title, author: $author) {\r\n    success\r\n    book {\r\n      title\r\n      author\r\n    }\r\n  }\r\n}",
